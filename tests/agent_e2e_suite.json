{
  "测试集": {
    "名称": "Agent E2E 评测",
    "版本": "v2-2026-02-13",
    "测试类型": "E2E",
    "bot_id": "7590989896576352256",
    "说明": [
      "本测试集用于验证生产 Agent 的端到端能力（真实工作流，不使用 STUB）。",
      "覆盖意图路由、参数提取、工作流执行、回复质量与交互规范。",
      "包含单轮与多轮场景，支持跨意图切换和高风险补槽路径验证。",
      "邮件到达邮箱属于外部交付结果，不纳入自动判定；以 workflow tool_output 成功为准。"
    ]
  },
  "默认配置": {
    "测试user_id": "agent_e2e_test_user_001",
    "测试邮箱": "agent_e2e_test@example.com",
    "是否注入SystemContext": true,
    "是否使用流式首响": true
  },
  "评测维度": {
    "D1_意图路由": {
      "权重": 30,
      "评判方式": "自动",
      "通过标准": "实际技能与预期技能一致（追问/兜底场景要求不调用技能）",
      "说明": "失败代价最高，路由错误会导致后续全部偏离。"
    },
    "D2_参数完整": {
      "权重": 20,
      "评判方式": "自动",
      "通过标准": "预期参数全部匹配（支持 keyword/action 归一化）",
      "说明": "路径正确但参数错误仍会导致业务结果错误。"
    },
    "D3_工作流执行": {
      "权重": 20,
      "评判方式": "自动",
      "通过标准": "当预期调用工作流时，消息中出现非错误 tool_output",
      "说明": "E2E 特有维度，用于区分调度正确但下游执行失败。"
    },
    "D4_回复质量": {
      "权重": 15,
      "评判方式": "AI-Judge",
      "通过标准": "1-5 分制，单条 >= 3 分；总体均分 >= 3.5",
      "说明": "功能正确之外，衡量用户可读性、完整性与无幻觉。"
    },
    "D5_交互规范": {
      "权重": 15,
      "评判方式": "混合",
      "通过标准": "关键词命中 + AI-Judge >= 3 分",
      "说明": "衡量追问精度、拒绝得体性与多轮连贯性。"
    }
  },
  "验收门槛": {
    "整体通过率": 80,
    "稳定性通过率": 90,
    "D1_意图路由": 95,
    "D2_参数完整": 90,
    "D3_工作流执行": 90,
    "D4_回复质量_平均分": 3.5,
    "D5_交互规范": 85
  },
